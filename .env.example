# Supabase — from your project settings at supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Free-tier AI providers used by the AI coach
# Groq: console.groq.com/keys (fast, generous free tier)
GROQ_API_KEY=

# OpenRouter: openrouter.ai/keys (fallback, has free models e.g. meta-llama/llama-3.1-8b-instruct:free)
OPENROUTER_API_KEY=

# Max AI coach messages per user per day (protects free-tier quota)
AI_DAILY_MESSAGE_LIMIT=20
